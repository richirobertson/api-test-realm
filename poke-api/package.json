{
  "name": "api-test-realm",
  "version": "1.0.0",
  "private": true,
  "description": "A starter Node.js API with an automated Supertest suite.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "npm run test:unit",
    "test:unit": "jest --runInBand --testPathIgnorePatterns=test/live",
    "test:mocked": "jest test/mocked --runInBand",
    "test:live": "jest test/live --runInBand",
    "test:live:report": "mkdir -p reports && jest test/live --runInBand --json --outputFile=reports/live-test-results.json",
    "test:all": "jest --runInBand",
    "test:watch": "jest --watch --testPathIgnorePatterns=test/live"
  },
  "jest": {
    "setupFilesAfterEnv": [
      "<rootDir>/test/support/setup.js"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "dotenv": "^17.4.2",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
