{
  "name": "open-meteo-test-realm",
  "version": "1.0.0",
  "private": true,
  "description": "An Open-Meteo API-testing example with a small weather CLI.",
  "bin": {
    "weather": "src/cli.js"
  },
  "scripts": {
    "weather": "node src/cli.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest test/mocked --runInBand --verbose",
    "test:mocked": "jest test/mocked --runInBand --verbose",
    "test:mocked:report": "mkdir -p reports coverage && jest test/mocked --runInBand --verbose --json --outputFile=reports/mocked-test-results.json --coverage --coverageDirectory=coverage --coverageReporters=json-summary --coverageReporters=lcov",
    "test:live": "jest test/live --runInBand --verbose",
    "test:live:report": "mkdir -p reports && jest test/live --runInBand --verbose --json --outputFile=reports/live-test-results.json",
    "test:all": "jest test/mocked test/live --runInBand --verbose"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.6"
  },
  "allowScripts": {
    "unrs-resolver@1.12.2": true,
    "fsevents@2.3.3": true
  }
}
